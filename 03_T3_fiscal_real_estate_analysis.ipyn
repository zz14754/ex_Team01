            "sale_area     5.654e-06   2.18e-06      2.593      0.010    1.37e-06    9.94e-06\n",
            "re_invest    -6.218e-06   2.57e-06     -2.416      0.016   -1.13e-05   -1.16e-06\n",
            "re_avg_price -1.617e-07   2.64e-07     -0.613      0.540   -6.79e-07    3.56e-07\n",
