      "source": [
        "# 数据清洗\n",
        "df_clean = df[(df['sale_area'] > 0) & (df['gap_to_gdp'] > -1) & (df['gap_to_gdp'] < 2)].copy()\n",
        "\n",
        "plt.figure(figsize=(12, 7))\n",
        "sns.regplot(x='sale_area', y='gap_to_gdp', data=df_clean, scatter_kws={'alpha':0.4, 's':50}, \n",
        "            line_kws={'color':'red', 'linewidth':2})\n",
        "plt.xscale('log')\n",
        "plt.title('商品房销售面积与财政缺口率的回归关系 (对数X轴)', fontsize=15, fontweight='bold')\n",
        "plt.xlabel('销售面积 (log)', fontsize=12)\n",
        "plt.ylabel('gap_to_gdp', fontsize=12)\n",
        "plt.grid(True, alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    },
    {
