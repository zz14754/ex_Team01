      ],
      "source": [
        "# 四象限分类\n",
        "sale_median = df['sale_area'].median()\n",
        "gap_median = df['gap_to_gdp'].median()\n",
        "\n",
        "df['quadrant'] = pd.cut(df['sale_area'], bins=[0, sale_median, np.inf], labels=['Low', 'High'], include_lowest=True).astype(str) + '_' + \\\n",
        "                  pd.cut(df['gap_to_gdp'], bins=[df['gap_to_gdp'].min()-0.01, gap_median, np.inf], labels=['Low', 'High'], include_lowest=True).astype(str)\n",
        "\n",
        "quadrant_map = {\n",
        "    'Low_Low': '稳健型（低销售、低缺口）',\n",
        "    'High_Low': '高依赖型（高销售、低缺口）',\n",
        "    'Low_High': '风险型（低销售、高缺口）',\n",
        "    'High_High': '高压型（高销售、高缺口）'\n",
        "}\n",
        "df['quadrant_name'] = df['quadrant'].map(quadrant_map)\n",
        "\n",
        "print(\"四象限城市分布：\")\n",
        "print(df['quadrant_name'].value_counts())\n",
        "print(\"\\\\n各象限的平均特征：\")\n",
        "print(df.groupby('quadrant_name')[['sale_area', 'gap_to_gdp', 're_invest']].mean())"
      ]
    },
    {
